{
  "name": "StudentCode",
  "type": "object",
  "properties": {
    "code": {
      "type": "string",
      "description": "C\u00f3digo \u00fanico do estudante (pr\u00e9-carregado pelo secret\u00e1rio)"
    },
    "student_name": {
      "type": "string",
      "description": "Nome completo do aluno"
    },
    "course": {
      "type": "string",
      "enum": [
        "T\u00e9cnico de Inform\u00e1tica",
        "Gest\u00e3o de Inform\u00e1tica",
        "Gest\u00e3o Empresarial",
        "Recursos Humanos",
        "Contabilidade",
        "Gest\u00e3o de Sistemas Inform\u00e1ticos"
      ],
      "description": "Curso do aluno"
    },
    "class_year": {
      "type": "string",
      "enum": [
        "10\u00aa",
        "11\u00aa",
        "12\u00aa",
        "13\u00aa"
      ],
      "description": "Classe/Ano"
    },
    "class_name": {
      "type": "string",
      "description": "Turma (ex: A, B, C)"
    },
    "period": {
      "type": "string",
      "enum": [
        "Manh\u00e3",
        "Tarde"
      ],
      "description": "Per\u00edodo de aulas"
    },
    "is_finalist": {
      "type": "boolean",
      "default": false,
      "description": "Se o aluno \u00e9 finalista"
    },
    "is_registered": {
      "type": "boolean",
      "default": false,
      "description": "Se o c\u00f3digo j\u00e1 foi usado para registo"
    },
    "registered_by": {
      "type": "string",
      "description": "Email do utilizador que se registou com este c\u00f3digo"
    }
  },
  "required": [
    "code",
    "student_name",
    "course",
    "class_year",
    "class_name",
    "period"
  ]
}