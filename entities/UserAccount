{
  "name": "UserAccount",
  "type": "object",
  "properties": {
    "credential": {
      "type": "string",
      "description": "C\u00f3digo de estudante ou n\u00famero de telefone"
    },
    "password": {
      "type": "string",
      "description": "Senha do utilizador"
    },
    "user_type": {
      "type": "string",
      "enum": [
        "aluno",
        "professor",
        "secretario",
        "encarregado"
      ],
      "description": "Tipo de conta"
    },
    "full_name": {
      "type": "string",
      "description": "Nome completo"
    },
    "email": {
      "type": "string",
      "description": "Email opcional"
    },
    "phone": {
      "type": "string",
      "description": "N\u00famero de telefone"
    },
    "student_code": {
      "type": "string",
      "description": "C\u00f3digo de estudante (apenas para alunos)"
    },
    "is_active": {
      "type": "boolean",
      "default": true
    },
    "is_suspended": {
      "type": "boolean",
      "default": false,
      "description": "Se a conta est\u00e1 suspensa"
    },
    "suspension_end_date": {
      "type": "string",
      "format": "date",
      "description": "Data de fim da suspens\u00e3o"
    },
    "notifications_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Se as notifica\u00e7\u00f5es push est\u00e3o ativas"
    }
  },
  "required": [
    "credential",
    "password",
    "user_type",
    "full_name"
  ]
}