{
  "name": "Attendance",
  "type": "object",
  "properties": {
    "student_code": {
      "type": "string",
      "description": "C\u00f3digo do estudante"
    },
    "student_name": {
      "type": "string",
      "description": "Nome do estudante"
    },
    "subject": {
      "type": "string",
      "description": "Disciplina"
    },
    "teacher_email": {
      "type": "string",
      "description": "Email do professor"
    },
    "date": {
      "type": "string",
      "format": "date",
      "description": "Data da aula"
    },
    "status": {
      "type": "string",
      "enum": [
        "Presente",
        "Falta",
        "Falta Justificada",
        "Atraso"
      ],
      "description": "Estado de presen\u00e7a"
    },
    "justification": {
      "type": "string",
      "description": "Justifica\u00e7\u00e3o (se aplic\u00e1vel)"
    },
    "course": {
      "type": "string"
    },
    "class_year": {
      "type": "string"
    },
    "class_name": {
      "type": "string"
    }
  },
  "required": [
    "student_code",
    "subject",
    "date",
    "status"
  ]
}